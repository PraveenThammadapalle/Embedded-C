//   pointer-level mistake question


 #include <stdio.h>
        void main()
        {
            int a[3] = {1, 2, 3};
            int *p = a;
            int **r = &p;
            printf("%d\n", (**r));
        }
        
////////////////////////        
int *p = a;
int *r = &p;   // ❌ wrong type

r → address of p
*r → p
**r → *p → a[0] → 1

🖨 Output
1
