#include<stdio.h>
#include <string.h>
void fun(char **p)
{
    char *t;
    t = (p += 2)[-1];
    printf("%s\n", t);
}

int main()
{
    char *argv[] = {"ab","cd","ef","gh"};
    fun(argv);
    return 0;
}   
output: cd
