////////////very important pointer-to-pointer lifetime bug

#include <stdio.h>
        void foo(int **p);
        int main()
        {
            int i = 10;
            int *p = &i;
            foo(&p);
            printf("%d ", *p);
        }
        void foo(int **p)
        {
            int j = 11;
            *p = &j;
            //**p = 11; // modify value instead of pointer   //Safe because p still points to i.
            printf("%d ", **p);
        }
