///////////
#include <stdio.h>
        void foo(int *const *p);
        int main()
        {
            int i = 11;
            int *p = &i;
            foo(&p);
            printf("%d ", *p);
        }
        void foo(int *const *p)
        {
            int j = 10;
            *p = &j;
            printf("%d ", **p);
        }
        
///////////////////////////
It tests:
1.pointer-to-pointer
2.const placement meaning
3.dangling pointer bug
4.what you are allowed to modify vs not

void foo(int *const *p);   in this line
p          → pointer
*p         → pointer to int (int *)
*const     → this pointer cannot be changed

